# =========================
# Node.js / Cloud Functions
# =========================
node_modules/
npm-debug.log
yarn-error.log
.env
.firebase/
firebase-debug.log
firebase-debug.*.log

# =========================
# Flutter / Dart
# =========================
.dart_tool/
.packages
build/
.pub-cache/
.pub/
# pubspec.lock se commitea en apps Flutter para garantizar versiones consistentes entre devs
# pubspec.lock

# Código generado (build_runner)
*.g.dart
*.freezed.dart

# Firebase config generado por FlutterFire CLI (contiene credenciales)
lib/firebase_options.dart

# Credenciales de plataforma (se agregan por cada developer según su proyecto Firebase)
/android/app/src/main/res/values/secrets.xml
/android/app/google-services.json
/ios/Runner/GoogleService-Info.plist

# Directorios de plataforma generados por flutter create (commitear solo la versión limpia)
# android/ y ios/ SÍ se commitean — son necesarios para el build

# =========================
# IDEs y OS
# =========================
.idea/
# .vscode/ ignorado excepto configuraciones compartidas del equipo
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json
*.iml
.DS_Store
Thumbs.db

# Entornos locales de IAs
.gemini/

